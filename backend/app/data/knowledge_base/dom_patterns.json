  "salary": ".salary, [itemprop='baseSalary']",
  "job_type": "[itemprop='employmentType']",
  "apply_url": "a[data-apply-url], a.apply-button",
  "responsibilities": "section, article, [data-section='responsibilities']",
  "qualifications": "section, article, [data-section='qualifications']",
  "benefits": "section, article, [data-section='benefits']",
