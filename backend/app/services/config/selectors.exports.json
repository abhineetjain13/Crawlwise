{
  "TITLE_SELECTOR": "h1 a, h2 a, h3 a, h4 a, h5 a, h1, h2, h3, h4, h5",
  "ANCHOR_SELECTOR": "a[href]",
  "DOM_PATTERNS": {
    "__type__": "dict",
    "items": [
      {
        "key": "apply_url",
        "value": "a[data-apply-url], a.apply-button"
      },
      {
        "key": "availability",
        "value": "[itemprop='availability'], .availability, [data-stock], [data-availability]"
      },
      {
        "key": "benefits",
        "value": "[data-section='benefits'], .benefits, #benefits"
      },
      {
        "key": "brand",
        "value": "[itemprop='brand'], .brand, .product-brand, [data-testid*='brand'], [aria-label*='brand'], [class*='Brand']"
      },
      {
        "key": "category",
        "value": "[itemprop='category'], nav.breadcrumb li:last-child"
      },
      {
        "key": "company",
        "value": ".company-name, [itemprop='hiringOrganization'] [itemprop='name']"
      },
      {
        "key": "description",
        "value": "[itemprop='description'], .product-description, [data-description], meta[name='description'], meta[property='og:description']"
      },
      {
        "key": "features",
        "value": "[data-section='features'], .features, .product-features, #features"
      },
      {
        "key": "image_url",
        "value": "[itemprop='image'], meta[property='og:image'], [data-testid*='image'], [class*='product-image'], [class*='ProductImage'], img[itemprop='image']"
      },
      {
        "key": "job_type",
        "value": "[itemprop='employmentType']"
      },
      {
        "key": "location",
        "value": ".job-location, [itemprop='jobLocation'] [itemprop='name']"
      },
      {
        "key": "original_price",
        "value": ".original-price, .compare-price, [data-original-price], [data-testid*='original-price'], [class*='OriginalPrice'], [class*='compare-price'], [aria-label*='original price']"
      },
      {
        "key": "price",
        "value": "[itemprop='price'], .price, .product-price, [data-testid*='price'], [data-test*='price'], [class*='Price'], [class*='price-'], [aria-label*='price'], [data-price]"
      },
      {
        "key": "qualifications",
        "value": "[data-section='qualifications'], .qualifications, #qualifications"
      },
      {
        "key": "rating",
        "value": "[itemprop='ratingValue'], [data-testid*='rating'], [class*='Rating'], [class*='rating'], [aria-label*='rating'], [class*='stars']"
      },
      {
        "key": "responsibilities",
        "value": "[data-section='responsibilities'], .responsibilities, #responsibilities"
      },
      {
        "key": "review_count",
        "value": "[itemprop='reviewCount'], [data-testid*='review'], [class*='review-count'], [class*='ReviewCount'], [aria-label*='review']"
      },
      {
        "key": "salary",
        "value": ".salary, [itemprop='baseSalary']"
      },
      {
        "key": "sale_price",
        "value": ".sale-price, .discount-price, [data-sale-price], [data-testid*='sale-price'], [class*='SalePrice'], [class*='sale-price'], [aria-label*='sale price']"
      },
      {
        "key": "skills",
        "value": "[data-section='skills'], .skills, #skills"
      },
      {
        "key": "sku",
        "value": "[itemprop='sku']"
      },
      {
        "key": "specifications",
        "value": "[data-section='specifications'], .specifications, .product-specifications, #specifications"
      },
      {
        "key": "title",
        "value": "h1, [itemprop='name'], meta[property='og:title'], title, [data-testid*='title'], [data-testid*='product-name'], [class*='ProductTitle'], [class*='product-title'], [aria-label*='product name']"
      }
    ]
  },
