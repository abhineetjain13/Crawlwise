APP_ENV=development

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_URL=http://127.0.0.1:3000
FRONTEND_ORIGINS=

JWT_SECRET_KEY=replace-with-64-byte-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
ENCRYPTION_KEY=replace-with-32-byte-minimum-secret

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/crawlerai
REDIS_URL=redis://localhost:6379/0
REDIS_STATE_ENABLED=false
CELERY_DISPATCH_ENABLED=false
LEGACY_INPROCESS_RUNNER_ENABLED=true

ARTIFACTS_DIR=./backend/artifacts
ACQUISITION_CACHE_DIR=./backend/artifacts/acquisition_cache
COOKIE_STORE_DIR=./backend/cookie_store
PLAYWRIGHT_HEADLESS=true

ANTHROPIC_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=

REQUEST_ID_HEADER=X-Request-ID
CRAWL_LOG_DB_MIN_LEVEL=info
CRAWL_LOG_DB_URL_PROGRESS_SAMPLE_RATE=4
CRAWL_LOG_DB_MAX_ROWS_PER_RUN=1000
CRAWL_LOG_FILE_ENABLED=true
CRAWL_LOG_FILE_DIR=./backend/artifacts/run_logs
SYSTEM_MAX_CONCURRENT_URLS=8

DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=replace-with-strong-admin-password
BOOTSTRAP_ADMIN_ONCE=false
REGISTRATION_ENABLED=false

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SECONDS=600
DB_POOL_TIMEOUT_SECONDS=10
DB_POOL_PRE_PING=true
